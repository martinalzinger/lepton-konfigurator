#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
STEP -> GLB Konverter (Fenster-Programm) - Alzinger Lepton-Ersatzteilkatalog.
STEP-Datei waehlen -> "In GLB umwandeln" -> fertige .glb liegt daneben.
Voraussetzung: Python 3 (Windows: "Add python.exe to PATH" beim Setup anhaken).
cascadio installiert sich beim ersten Start automatisch.
"""
import sys, os, struct, threading, subprocess, traceback, time
import tkinter as tk
from tkinter import filedialog, ttk, messagebox

LOGO_B64 = ""

RED="#c00000"; RED2="#9d0000"; INK="#16181a"; PAPER="#f1f1ee"
CARD="#ffffff"; FIELD="#f7f6f2"; MUTED="#5e6166"; FAINT="#9a9aa0"
LINE="#e4e2db"; GOLD="#a28231"

LEVELS = {
    "Standard (empfohlen)":                  dict(tol_linear=0.08, tol_angular=1.0),
    "Fein (mehr Details, groessere Datei)":  dict(tol_linear=0.03, tol_angular=0.6),
    "Grob (kleiner, fuer grosse Baugruppen)":dict(tol_linear=0.15, tol_angular=2.0),
}

def ensure(pkg, importname=None):
    try:
        __import__(importname or pkg); return True, ""
    except ImportError:
        try:
            subprocess.run([sys.executable,"-m","pip","install",pkg],capture_output=True,text=True)
            __import__(importname or pkg); return True, ""
        except Exception as e:
            return False, str(e)

class App:
    def __init__(self, root):
        self.root=root; self.path=None
        root.title("Alzinger · STEP → GLB Konverter")
        root.configure(bg=PAPER); root.geometry("600x600"); root.minsize(560,560)

        style=ttk.Style(root)
        try: style.theme_use("clam")
        except Exception: pass
        style.configure("Red.Horizontal.TProgressbar",troughcolor=LINE,background=RED,
                        bordercolor=LINE,lightcolor=RED,darkcolor=RED)
        style.configure("TCombobox",fieldbackground=FIELD,background=FIELD,arrowsize=16)

        # --- roter Header mit Logo ---
        header=tk.Frame(root,bg=RED,height=70); header.pack(fill="x"); header.pack_propagate(False)
        hin=tk.Frame(header,bg=RED); hin.pack(fill="both",expand=True,padx=22)
        try:
            img=tk.PhotoImage(data=LOGO_B64)
            fac=max(1,int(img.height()/30)); self.logo=img.subsample(fac,fac)
            tk.Label(hin,image=self.logo,bg=RED).pack(side="left")
        except Exception:
            tk.Label(hin,text="ALZINGER",bg=RED,fg="white",font=("Segoe UI",16,"bold")).pack(side="left")
        tk.Label(hin,text="ERSATZTEILE",bg=RED,fg="#ffd9d9",
                 font=("Consolas",10,"bold")).pack(side="right")

        tk.Label(root,text="STEP → GLB Konverter",bg=PAPER,fg=INK,
                 font=("Segoe UI",18,"bold")).pack(pady=(18,0))
        tk.Label(root,text="LEPTON 5100  ·  3D-BAUGRUPPEN",bg=PAPER,fg=MUTED,
                 font=("Consolas",9)).pack(pady=(3,0))

        card=tk.Frame(root,bg=CARD,highlightbackground=LINE,highlightthickness=1)
        card.pack(fill="both",expand=True,padx=20,pady=16)

        self._step(card,"1","STEP-Datei wählen")
        self.fbtn=tk.Button(card,text="Datei auswählen …",command=self.choose,
                 bg=RED,fg="white",activebackground=RED2,activeforeground="white",
                 relief="flat",font=("Segoe UI",11,"bold"),padx=12,pady=9,cursor="hand2",bd=0)
        self.fbtn.pack(fill="x",padx=20,pady=(2,5))
        self.filevar=tk.StringVar(value="Keine Datei gewählt")
        tk.Label(card,textvariable=self.filevar,bg=CARD,fg=MUTED,font=("Consolas",9),
                 wraplength=500,justify="left").pack(fill="x",padx=20)

        self._step(card,"2","Detailgrad")
        self.level=tk.StringVar(value="Standard (empfohlen)")
        ttk.Combobox(card,textvariable=self.level,values=list(LEVELS.keys()),
                     state="readonly").pack(fill="x",padx=20,pady=(2,2))

        self._step(card,"3","Umwandeln")
        self.btn=tk.Button(card,text="In GLB umwandeln",command=self.start,
                 bg=INK,fg="white",activebackground="#000000",activeforeground="white",
                 relief="flat",font=("Segoe UI",11,"bold"),padx=12,pady=10,cursor="hand2",bd=0)
        self.btn.pack(fill="x",padx=20,pady=(2,8))

        self.prog=ttk.Progressbar(card,mode="indeterminate",style="Red.Horizontal.TProgressbar")
        self.prog.pack(fill="x",padx=20)

        self.log=tk.Text(card,height=6,bg=FIELD,fg=INK,relief="flat",font=("Consolas",9),
                 wrap="word",bd=0,padx=10,pady=8,highlightbackground=LINE,highlightthickness=1)
        self.log.pack(fill="both",expand=True,padx=20,pady=12)

        tk.Label(root,text="martin@alzinger-maschinenbau.de",bg=PAPER,fg=FAINT,
                 font=("Consolas",8)).pack(pady=(0,8))

        self.say("Bereit. STEP-Datei wählen und auf „In GLB umwandeln“ klicken.\n"
                 "Tipp: bei sehr großen Baugruppen „Grob“ wählen.")
        if len(sys.argv)>1 and os.path.isfile(sys.argv[1]): self.set_path(sys.argv[1])

    def _step(self,parent,num,title):
        row=tk.Frame(parent,bg=CARD); row.pack(fill="x",padx=18,pady=(14,0))
        b=tk.Label(row,text=num,bg=GOLD,fg="white",font=("Segoe UI",10,"bold"),width=3,height=1)
        b.pack(side="left")
        tk.Label(row,text="  "+title,bg=CARD,fg=INK,font=("Segoe UI",11,"bold")).pack(side="left")

    def say(self,msg,clear=True):
        if clear: self.log.delete("1.0","end")
        self.log.insert("end",msg); self.log.see("end"); self.root.update_idletasks()

    def choose(self):
        p=filedialog.askopenfilename(title="STEP-Datei wählen",
            filetypes=[("STEP oder ZIP","*.stp *.step *.zip"),("Alle Dateien","*.*")])
        if p: self.set_path(p)

    def set_path(self,p):
        self.path=p; mb=os.path.getsize(p)/1e6
        self.filevar.set(os.path.basename(p)+"   ("+("%.1f"%mb)+" MB)")

    def start(self):
        if not self.path:
            messagebox.showinfo("Hinweis","Bitte zuerst eine STEP-Datei wählen."); return
        self.btn.config(state="disabled"); self.fbtn.config(state="disabled"); self.prog.start(12)
        threading.Thread(target=self.run,daemon=True).start()

    def run(self):
        try:
            self.say("Bereite vor … (Umwandel-Bibliothek prüfen/installieren – nur beim 1. Mal)")
            ok,err=ensure("cascadio")
            if not ok:
                self.say("FEHLER beim Installieren von 'cascadio':\n"+err+
                         "\n\nInternet prüfen und erneut starten."); return
            import cascadio
            src=self.path
            if self.path.lower().endswith(".zip"):
                import zipfile, tempfile
                self.say("Entpacke ZIP …")
                zf=zipfile.ZipFile(self.path)
                steps=[n for n in zf.namelist() if n.lower().endswith((".stp",".step"))]
                if not steps:
                    self.say("FEHLER: In der ZIP ist keine STEP-Datei (.stp/.step) enthalten."); zf.close(); return
                src=zf.extract(steps[0], tempfile.mkdtemp()); zf.close()
            out=os.path.splitext(self.path)[0]+".glb"; p=LEVELS[self.level.get()]
            self.say("Konvertiere:\n"+os.path.basename(src)+"\nDetailgrad: "+self.level.get()+
                     "\n\nBitte warten – das rechnet (je nach Größe einige Minuten) …")
            t=time.time()
            cascadio.step_to_glb(src,out,tol_linear=p["tol_linear"],tol_angular=p["tol_angular"],
                                 tol_relative=True,merge_primitives=True,use_parallel=True)
            if not os.path.exists(out):
                self.say("FEHLER: Es wurde keine GLB erzeugt.\nIst die gewählte Datei wirklich eine gültige STEP-Datei?\n"
                         "Bei sehr großen Baugruppen evtl. zu wenig Arbeitsspeicher – dann in Teil-Baugruppen exportieren."); return
            data=open(out,"rb").read(); magic,_v,ln=struct.unpack("<III",data[:12])
            valid=(hex(magic)=="0x46546c67" and ln==len(data)); mb=len(data)/1e6; tris=""
            if ensure("trimesh")[0]:
                try:
                    import trimesh; s=trimesh.load(out)
                    tris="Dreiecke: "+format(sum(len(g.faces) for g in s.geometry.values()),",")+"\n"
                except Exception: pass
            msg=("FERTIG ✓   ("+("%.0f"%(time.time()-t))+"s)\n\n"
                 "GLB: "+os.path.basename(out)+"\nGröße: "+("%.1f"%mb)+" MB\n"+tris+
                 "Gültig: "+("JA" if valid else "NEIN – bitte melden")+"\n\n"
                 "Liegt neben der STEP-Datei:\n"+out)
            if mb>28:
                msg+="\n\n⚠ Über 28 MB. Tipp: Detailgrad „Grob“ wählen oder die .glb zippen."
            self.say(msg)
        except Exception as e:
            self.say("FEHLER:\n"+str(e)+"\n\n"+traceback.format_exc())
        finally:
            self.prog.stop(); self.btn.config(state="normal"); self.fbtn.config(state="normal")

if __name__=="__main__":
    root=tk.Tk(); App(root); root.mainloop()
